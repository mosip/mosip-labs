# GitHub Personal Access Token (required for sync endpoints)
# Create at: https://github.com/settings/tokens (scope: repo)
GITHUB_TOKEN=ghp_your_token_here

# Database - use RDS_* for external DB (e.g. AWS RDS); or POSTGRES_* for Docker db
RDS_HOST=your-rds-host-or-db
RDS_PORT=5432
RDS_DATABASE=github_tracker
RDS_USER=postgres
RDS_PASSWORD=your-password

# For local Docker db only (when RDS_* not set):
# POSTGRES_DB=github_data
# POSTGRES_USER=github_user
# POSTGRES_PASSWORD=github_password

# CORS - use port number with colon, e.g. http://localhost:80
ALLOWED_ORIGINS=http://localhost,http://localhost:80
